# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/event_management

# Redis
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED=false

# JWT
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Brevo Email
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Event Management

# QR Encryption
QR_ENCRYPTION_KEY=your-32-character-encryption-key-here
QR_IMAGE_BASE_URL=http://localhost:5000

# Cookie
COOKIE_SECRET=your-cookie-secret-change-in-production

# Cloudinary (profile photos)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
